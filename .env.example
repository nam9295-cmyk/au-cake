VITE_MARKET=KR
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_CAKE_DATABASE_ID=verygood_cake
VITE_APPWRITE_KIDS_DATABASE_ID=verygood_cake
VITE_APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
VITE_APPWRITE_SETTINGS_TABLE_ID=settings
VITE_APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
VITE_APPWRITE_KIDS_BOOKED_DATES_TABLE_ID=class_booked_dates
VITE_APPWRITE_CAKE_PICKUP_OPENINGS_TABLE_ID=cake_pickup_openings
VITE_ADMIN_EMAILS=admin@example.com

# Staged migration safety: off keeps the current direct-write flow unchanged.
# Use lookup only after reservation-api health check; use all only before closing public create permissions.
VITE_RESERVATION_API_MODE=off
VITE_RESERVATION_API_FUNCTION_ID=reservation-api

APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_CAKE_DATABASE_ID=verygood_cake
APPWRITE_KIDS_DATABASE_ID=verygood_cake
APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
APPWRITE_SETTINGS_TABLE_ID=settings
APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
APPWRITE_KIDS_BOOKED_DATES_TABLE_ID=class_booked_dates
APPWRITE_CAKE_PICKUP_OPENINGS_TABLE_ID=cake_pickup_openings
# Required. Setup stops without named administrator user IDs.
APPWRITE_ADMIN_USER_IDS=

# direct keeps public creates open. Change to function only after the frontend all-mode smoke test.
APPWRITE_RESERVATION_WRITE_MODE=direct
APPWRITE_RESERVATION_API_FUNCTION_ID=reservation-api
APPWRITE_RESERVATION_API_RUNTIME=node-16.0

APPWRITE_RESERVATION_NOTIFY_FUNCTION_ID=reservation-notification
APPWRITE_RESERVATION_NOTIFY_RUNTIME=node-16.0
APPWRITE_RESERVATION_CREATE_EVENT=
RESEND_API_KEY=
RESEND_FROM_EMAIL="Reservation <reservation@example.com>"
RESEND_TO_EMAILS="owner@example.com"

# AU example:
# VITE_MARKET=AU
# VITE_APPWRITE_CAKE_DATABASE_ID=verygood_cake_au
# VITE_APPWRITE_KIDS_DATABASE_ID=your_au_kids_database_id
# VITE_APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
# VITE_APPWRITE_SETTINGS_TABLE_ID=settings
# VITE_APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
# APPWRITE_CAKE_DATABASE_ID=verygood_cake_au
# APPWRITE_KIDS_DATABASE_ID=your_au_kids_database_id
# APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
# APPWRITE_SETTINGS_TABLE_ID=settings
# APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
