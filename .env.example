VITE_MARKET=KR
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_CAKE_DATABASE_ID=verygood_cake
VITE_APPWRITE_KIDS_DATABASE_ID=verygood_cake
VITE_APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
VITE_APPWRITE_SETTINGS_TABLE_ID=settings
VITE_APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
VITE_APPWRITE_KIDS_BOOKED_DATES_TABLE_ID=class_booked_dates
VITE_APPWRITE_CAKE_PICKUP_OPENINGS_TABLE_ID=cake_pickup_openings
VITE_APPWRITE_REVIEW_INVITES_TABLE_ID=review_invites
VITE_APPWRITE_REVIEWS_TABLE_ID=reviews
VITE_APPWRITE_REVIEW_COUPONS_TABLE_ID=review_coupons
VITE_APPWRITE_REVIEW_PHOTO_CLEANUP_TABLE_ID=review_photo_cleanup
VITE_APPWRITE_REVIEW_PHOTOS_BUCKET_ID=review-photos
# Public showcase and private review requests stay disabled unless this Function id is explicit.
VITE_REVIEW_API_FUNCTION_ID=
# Direct HTTPS domain of review-api, used only by authenticated admins to fetch private photo previews.
# Leave blank until the Function domain and exact CORS origins are configured.
VITE_REVIEW_API_DIRECT_URL=
# Dev-only showcase fixtures require both Vite dev mode and this exact opt-in.
VITE_REVIEW_DEMO_MODE=false
VITE_ADMIN_EMAILS=admin@example.com

# Staged migration safety: off keeps the current direct-write flow unchanged.
# Use lookup only after reservation-api health check; use all only before closing public create permissions.
VITE_RESERVATION_API_MODE=off
VITE_RESERVATION_API_FUNCTION_ID=reservation-api

APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_CAKE_DATABASE_ID=verygood_cake
APPWRITE_KIDS_DATABASE_ID=verygood_cake
APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
APPWRITE_SETTINGS_TABLE_ID=settings
APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
APPWRITE_KIDS_BOOKED_DATES_TABLE_ID=class_booked_dates
APPWRITE_CAKE_PICKUP_OPENINGS_TABLE_ID=cake_pickup_openings
APPWRITE_REVIEW_INVITES_TABLE_ID=review_invites
APPWRITE_REVIEWS_TABLE_ID=reviews
APPWRITE_REVIEW_COUPONS_TABLE_ID=review_coupons
# Cleanup schema: reasons include staged_upload; statuses staging/pending/failed; 9 attempts dead-letter.
APPWRITE_REVIEW_PHOTO_CLEANUP_TABLE_ID=review_photo_cleanup
APPWRITE_REVIEW_PHOTOS_BUCKET_ID=review-photos
# Schema resource administrators. Required by setup:appwrite.
APPWRITE_ADMIN_USER_IDS=
# Review API request administrators. Kept separate from schema administrators.
REVIEW_ADMIN_USER_IDS=
# Exact comma-separated HTTPS frontend origins allowed to request private admin photo previews.
# No wildcard, path, credentials, or trailing slash. Example: https://au.example.com
REVIEW_FRONTEND_ORIGINS=
APPWRITE_REVIEW_API_FUNCTION_ID=review-api
# sharp@0.34.5 requires Node 18.17+; node-16.0 is intentionally rejected.
APPWRITE_REVIEW_API_RUNTIME=node-20.0

# direct keeps public creates open. Change to function only after the frontend all-mode smoke test.
APPWRITE_RESERVATION_WRITE_MODE=direct
APPWRITE_RESERVATION_API_FUNCTION_ID=reservation-api
# This self-hosted Appwrite deployment exposes the transaction-compatible Node 16 runtime.
APPWRITE_RESERVATION_API_RUNTIME=node-16.0
# Server-only private coupon collections used for atomic one-time redemption. Never expose their permissions publicly.
APPWRITE_REVIEW_COUPONS_TABLE_ID=review_coupons
APPWRITE_MANUAL_COUPONS_TABLE_ID=manual_coupons
# One canonical base64url shared secret (at least 32 decoded bytes). Set the exact same value on
# review-api and reservation-api; never rotate it while any issued coupon remains active.
REVIEW_COUPON_HMAC_SECRET=
# Server-only raw code used only by `npm run issue:manual-coupon -- --apply`; never add a live value to source control.
MANUAL_COUPON_CODE=
# Separate canonical unpadded base64url value of exactly 32 decoded bytes. Never reuse the HMAC secret.
# Keep it unchanged while any issued coupon remains active; it is required to resend reward messages.
REVIEW_COUPON_ENCRYPTION_KEY=

APPWRITE_RESERVATION_NOTIFY_FUNCTION_ID=reservation-notification
APPWRITE_RESERVATION_NOTIFY_RUNTIME=node-16.0
APPWRITE_RESERVATION_CREATE_EVENT=
RESEND_API_KEY=
RESEND_FROM_EMAIL="Reservation <reservation@example.com>"
RESEND_TO_EMAILS="owner@example.com"

# AU example:
# VITE_MARKET=AU
# VITE_APPWRITE_CAKE_DATABASE_ID=verygood_cake_au
# VITE_APPWRITE_KIDS_DATABASE_ID=your_au_kids_database_id
# VITE_APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
# VITE_APPWRITE_SETTINGS_TABLE_ID=settings
# VITE_APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
# APPWRITE_CAKE_DATABASE_ID=verygood_cake_au
# APPWRITE_KIDS_DATABASE_ID=your_au_kids_database_id
# APPWRITE_CAKE_RESERVATIONS_TABLE_ID=reservations
# APPWRITE_SETTINGS_TABLE_ID=settings
# APPWRITE_KIDS_RESERVATIONS_TABLE_ID=class_reservations
